# ==========================================
# SmartGuard 环境变量配置
# 复制此文件为 .env 并填入实际值
# ==========================================

# --- OneNET 物联网平台 ---
# 产品 ID（OneNET 控制台 → 产品概况）
ONENET_PRODUCT_ID=YOUR_PRODUCT_ID
# 设备名称（设备注册时自定义）
ONENET_DEVICE_NAME=YOUR_DEVICE_NAME
# 设备 Key（设备详情页 → 设备密钥，Base64）
ONENET_DEVICE_KEY=YOUR_DEVICE_KEY
# MQTT Broker 地址（OneNET 标准接入点）
ONENET_MQTT_BROKER=183.230.40.96
# MQTT 端口（1883=非TLS, 8883=TLS）
ONENET_MQTT_PORT=1883

# --- SRS 视频推流 ---
# SRS 服务器 IP 地址
SRS_SERVER_IP=YOUR_SRS_SERVER_IP
# RTMP 推流地址（smartguard.cpp 中替换）
# rtmp://YOUR_SRS_SERVER_IP/live/camera

# --- Web 仪表板 (index.html) ---
# Access Key（OneNET 产品概况页）
ONENET_ACCESS_KEY=YOUR_ACCESS_KEY
# HTTP-FLV 拉流地址
# http://YOUR_SRS_SERVER_IP:8080/live/camera.flv
